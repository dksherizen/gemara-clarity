# Cloud frontier models (used for analytical passes 1, 2, 4, 6)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Local LM Studio (used for mechanical passes 3, 5)
# LM Studio exposes an OpenAI-compatible API. Default port is 1234.
# If LM Studio runs on a different machine, set the LAN IP here.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5-72b-instruct

# Default model selection per pipeline pass
# Set to one of: anthropic | openai | google | lmstudio
PASS_SEGMENTATION_PROVIDER=anthropic
PASS_STRUCTURE_PROVIDER=anthropic
PASS_PHRASEMAP_PROVIDER=lmstudio
PASS_MEFORSHIM_PROVIDER=anthropic
PASS_TEACHING_PROVIDER=lmstudio
PASS_VALIDATE_PROVIDER=openai
